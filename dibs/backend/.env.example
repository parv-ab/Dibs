# ---- core ----
NODE_ENV=development
PORT=4000

# ---- database (managed Postgres: Neon, Supabase, RDS, Railway) ----
DATABASE_URL=postgres://user:password@localhost:5432/dibs
PG_SSL=false                       # true for most managed hosts

# ---- secrets (generate: openssl rand -base64 48) ----
JWT_SECRET=change-me-long-random
CODE_PEPPER=change-me-different-long-random

# ---- token lifetimes ----
ACCESS_TTL=15m
REFRESH_TTL_DAYS=30

# ---- CORS (comma separated). capacitor://localhost is the iOS native origin ----
CORS_ORIGINS=http://localhost:5173,capacitor://localhost,http://localhost

# ---- email (Resend). Leave blank in dev to print codes to the console ----
RESEND_API_KEY=
EMAIL_FROM=dibs <login@yourdomain.app>

# ---- image storage (S3 / Cloudflare R2 / MinIO) ----
S3_REGION=us-east-1
S3_BUCKET=dibs-uploads
S3_ENDPOINT=                       # set for R2 / MinIO, blank for AWS
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CDN_BASE_URL=                      # e.g. https://cdn.yourdomain.app

# ---- signup policy ----
REQUIRE_EDU=true
